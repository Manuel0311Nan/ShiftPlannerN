generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

enum TipoTurno {
  APERTURA
  CIERRE
  PARTIDO
}

enum SolicitudEstado {
  PENDIENTE
  ACEPTADA
  RECHAZADA
}

model Empresa {
  id                     String                    @id @default(cuid())
  nombre                 String
  configuracion          Json                      @default("{}")
  trialEndsAt            DateTime
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  usuarios               Usuario[]
  turnos                 Turno[]
  locales                Local[]
  plantillasTurno        PlantillaTurno[]
  disponibilidades       Disponibilidad[]
  condiciones            CondicionTurno[]
  solicitudes            SolicitudDisponibilidad[]
  disponibilidadesSemana DisponibilidadSemana[]
}

model Usuario {
  id                   String                    @id @default(cuid())
  email                String                    @unique
  nombre               String
  passwordHash         String
  emailVerified        DateTime?
  image                String?
  rol                  Rol                       @default(EMPLOYEE)
  horasContrato        Int                       @default(40)
  diasLibres           Int                       @default(0)
  empresaId            String
  empresa              Empresa                   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  managerId            String?
  manager              Usuario?                  @relation("ManagerEmpleados", fields: [managerId], references: [id], onDelete: SetNull)
  empleados            Usuario[]                 @relation("ManagerEmpleados")
  localId              String?
  local                Local?                    @relation("EmpleadosLocal", fields: [localId], references: [id], onDelete: SetNull)
  localesComoManager   Local[]                   @relation("LocalesManager")
  disponibilidad       Disponibilidad[]
  condiciones          CondicionTurno[]
  solicitudes          SolicitudDisponibilidad[]
  disponibilidadSemana DisponibilidadSemana[]
  metadata             Json                      @default("{}")
  accounts             Account[]
  sessions             Session[]
  turnos               Turno[]
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@index([empresaId])
  @@index([managerId])
  @@index([localId])
}

model Local {
  id        String           @id @default(cuid())
  nombre    String
  empresaId String
  empresa   Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  managerId String
  manager   Usuario          @relation("LocalesManager", fields: [managerId], references: [id], onDelete: Cascade)
  plantilla PlantillaTurno[]
  empleados Usuario[]        @relation("EmpleadosLocal")
  createdAt DateTime         @default(now())

  @@index([empresaId])
  @@index([managerId])
}

model PlantillaTurno {
  id                 String    @id @default(cuid())
  empresaId          String
  empresa            Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  localId            String
  local              Local     @relation(fields: [localId], references: [id], onDelete: Cascade)
  diaSemana          DiaSemana
  nombre             String
  horaInicio         String
  horaFin            String
  personasRequeridas Int
  createdAt          DateTime  @default(now())

  @@index([empresaId])
  @@index([localId])
}

model Disponibilidad {
  id         String    @id @default(cuid())
  empresaId  String
  empresa    Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuarioId  String
  usuario    Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  diaSemana  DiaSemana
  horaInicio String
  horaFin    String
  createdAt  DateTime  @default(now())

  @@index([empresaId])
  @@index([usuarioId])
}

model CondicionTurno {
  id        String    @id @default(cuid())
  empresaId String
  empresa   Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuarioId String
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tipo      TipoTurno
  minimo    Int
  createdAt DateTime  @default(now())

  @@unique([usuarioId, tipo])
  @@index([empresaId])
  @@index([usuarioId])
}

/**
 * Solicitud de un trabajador para cambiar su disponibilidad en una semana
 * concreta. El manager la revisa y, si la acepta, define la disponibilidad de
 * esa semana (DisponibilidadSemana), que el motor usa al regenerar el horario.
 */
model SolicitudDisponibilidad {
  id            String          @id @default(cuid())
  empresaId     String
  empresa       Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuarioId     String
  usuario       Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  semanaInicio  DateTime
  motivo        String
  estado        SolicitudEstado @default(PENDIENTE)
  respuesta     String?
  resueltaPorId String?
  resueltaAt    DateTime?
  createdAt     DateTime        @default(now())

  @@index([empresaId])
  @@index([usuarioId])
  @@index([empresaId, estado])
}

/**
 * Override de disponibilidad para una semana concreta (lunes de esa semana en
 * `semanaInicio`). Si existen filas para (usuario, semana), el motor las usa en
 * lugar de la disponibilidad base al generar el horario de esa semana.
 */
model DisponibilidadSemana {
  id           String    @id @default(cuid())
  empresaId    String
  empresa      Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuarioId    String
  usuario      Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  semanaInicio DateTime
  diaSemana    DiaSemana
  horaInicio   String
  horaFin      String
  createdAt    DateTime  @default(now())

  @@index([empresaId])
  @@index([usuarioId, semanaInicio])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Turno {
  id        String   @id @default(cuid())
  inicio    DateTime
  fin       DateTime
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([empresaId])
  @@index([usuarioId, inicio, fin])
}
