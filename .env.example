# PostgreSQL (Neon)
# DATABASE_URL: conexión pooled (pgbouncer) — la usa la app en runtime
# DIRECT_URL: conexión directa (sin pooling) — la usa Prisma Migrate/CLI
DATABASE_URL="postgresql://usuario:password@localhost:5432/shiftplanner?schema=public"
DIRECT_URL="postgresql://usuario:password@localhost:5432/shiftplanner?schema=public"

# Auth.js (NextAuth v5)
AUTH_SECRET="genera-un-secreto-con-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
